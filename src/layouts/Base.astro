---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string | null;
  canonical?:   string | null;
}

const {
  title       = 'FILMCAT — Cinema en Català',
  description = 'FILMCAT — Totes les pel·lícules en català als cinemes de Catalunya. Horaris, sessions i cinemes actualitzats setmanalment.',
  ogImage     = null,
  canonical   = null,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="ca" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content={description}>
<meta name="theme-color" content="#0a0a0c">
<meta name="color-scheme" content="dark">
<!-- Security -->
<meta http-equiv="Content-Security-Policy" content="default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src https://image.tmdb.org data: blob:; connect-src https://api.themoviedb.org https://www.youtube.com https://filmcat-api.vercel.app; frame-ancestors 'none'; base-uri 'none'; form-action 'none';">
<meta http-equiv="X-Content-Type-Options" content="nosniff">
<meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">
<meta http-equiv="Permissions-Policy" content="geolocation=(), camera=(), microphone=()">
<!-- Open Graph -->
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:locale" content="ca_ES">
<meta property="og:url" content={canonical || 'https://filmcat.cat/'}>
{ogImage && <meta property="og:image" content={ogImage}>}
<meta name="twitter:card" content="summary_large_image">
{ogImage && <meta name="twitter:image" content={ogImage}>}
<title>{title}</title>
{canonical && <link rel="canonical" href={canonical}>}
<ViewTransitions />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style is:global>
/* ── RESET & TOKENS ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --red: #C0392B; --red-light: #E74C3C; --red-dark: #922B21; --red-focus: #ff6b5b;
  --bg: #0a0a0c; --bg2: #111115; --bg3: #18181e; --surface: #1e1e26; --surface2: #252530;
  --border: rgba(255,255,255,0.08); --text: #f0f0f0; --text-mid: rgba(240,240,240,0.72);
  --muted: rgba(255,255,255,0.45); --gold: #e8c97a;
  --px: clamp(16px, 4vw, 48px); --r-card: 12px; --r-modal: 20px;
}
html { scroll-behavior: smooth; background: #0a0a0c; color-scheme: dark; }
body { background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; font-size: 16px; line-height: 1.5; overflow-x: hidden; min-height: 100vh; }
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}
.visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
.skip-link { position: absolute; top: -100px; left: 16px; background: var(--red); color: white; padding: 10px 20px; border-radius: 0 0 8px 8px; font-weight: 700; font-size: 0.875rem; z-index: 9999; text-decoration: none; transition: top 0.2s; }
.skip-link:focus { top: 0; }
:focus-visible { outline: 3px solid var(--red-focus); outline-offset: 3px; border-radius: 4px; }
button:focus-visible, a:focus-visible { outline: 3px solid var(--red-focus); outline-offset: 3px; border-radius: 6px; }
body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9990; opacity: 0.28; }
/* ── HEADER ── */
header { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; justify-content: space-between; padding: 0.75rem var(--px); min-height: 64px; background: linear-gradient(to bottom, rgba(10,10,12,0.97) 0%, rgba(10,10,12,0) 100%); flex-wrap: wrap; gap: 8px; }
.logo-wrap { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--text); animation: float 7s ease-in-out infinite; }
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
.logo-svg { width: 34px; height: 30px; flex-shrink: 0; filter: drop-shadow(0 4px 14px rgba(192,57,43,.55)); }
.logo-text { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 4px; line-height: 1; }
nav { display: flex; align-items: center; gap: 24px; }
nav > a { color: var(--muted); text-decoration: none; font-size: 0.8rem; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; transition: color 0.2s; padding: 6px 2px; border-bottom: 2px solid transparent; }
nav > a:hover { color: var(--text); border-color: var(--red); }
.hamburger { display: none; background: none; border: none; cursor: pointer; padding: 6px 2px; color: var(--text); align-items: center; justify-content: center; min-width: 44px; min-height: 44px; }
.hamburger .menu-label { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: 3px; pointer-events: none; transition: color 0.2s; }
.hamburger[aria-expanded="true"] .menu-label { color: var(--red-light); }
.mobile-nav { display: none; position: fixed; inset: 4rem 0 0; background: rgba(10,10,12,0.97); z-index: 190; padding: 2rem var(--px); flex-direction: column; gap: 4px; backdrop-filter: blur(12px); }
.mobile-nav.open { display: flex; }
.mobile-nav a { color: var(--text); text-decoration: none; font-size: 1.625rem; font-family: 'Bebas Neue', sans-serif; letter-spacing: 3px; padding: 0.875rem 0; border-bottom: 1px solid var(--border); }
/* ── HERO ── */
.hero { position: relative; display: flex; flex-direction: column; justify-content: flex-end; padding: 5rem var(--px) clamp(1.75rem, 4vw, 2.75rem); overflow: hidden; }
.hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 65% 35%, rgba(192,57,43,.14) 0%, transparent 60%), radial-gradient(ellipse at 15% 75%, rgba(146,43,33,.09) 0%, transparent 50%); }
.hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%); }
.hero-content { position: relative; z-index: 2; }
.hero-eyebrow { font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 4px; color: var(--red-light); text-transform: uppercase; margin-bottom: 14px; display: flex; align-items: center; gap: 10px; }
.hero-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--red); flex-shrink: 0; }
h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.25rem, 6vw, 4.5rem); line-height: 0.92; letter-spacing: 2px; margin-bottom: 14px; }
h1 em { color: var(--red-light); font-style: normal; }
.hero-sub { font-size: clamp(0.8rem, 1.5vw, 0.95rem); color: var(--text-mid); font-weight: 300; max-width: 500px; line-height: 1.6; margin-bottom: 20px; }
.hero-stats { display: flex; gap: clamp(1rem, 3vw, 2rem); flex-wrap: wrap; margin-top: 4px; }
.stat { display: flex; flex-direction: column; gap: 3px; }
.stat-num { font-family: 'Bebas Neue', sans-serif; font-size: clamp(1.625rem,4vw,2.125rem); line-height: 1; }
.stat-label { font-size: 0.65rem; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; }
.scroll-hint { position: absolute; bottom: 24px; right: var(--px); display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--muted); font-size: 0.55rem; letter-spacing: 2px; text-transform: uppercase; }
.scroll-line { width: 1px; height: 36px; background: linear-gradient(to bottom, var(--red), transparent); animation: scrollAnim 1.8s ease-in-out infinite; }
@keyframes scrollAnim { 0% { transform: scaleY(0); transform-origin: top; } 50% { transform: scaleY(1); transform-origin: top; } 51% { transform: scaleY(1); transform-origin: bottom; } 100%{ transform: scaleY(0); transform-origin: bottom; } }
/* ── MAIN ── */
main { padding: 0 var(--px) 80px; }
/* ── FILTER BAR ── */
.filter-bar { display: flex; gap: 0.5rem; overflow-x: auto; scrollbar-width: none; padding-bottom: 0.25rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.filter-bar::-webkit-scrollbar { display: none; }
.filter-bar + .filter-bar { margin-top: 10px; }
.filter-btn { flex-shrink: 0; padding: 0.5rem 1.1rem; border-radius: 40px; border: 1.5px solid var(--border); background: transparent; color: var(--text-mid); font-family: 'Outfit', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 1px; cursor: pointer; transition: all 0.18s; text-transform: uppercase; min-height: 44px; }
.filter-btn:hover { border-color: rgba(192,57,43,.5); color: var(--text); }
.filter-btn.active { background: var(--red); border-color: var(--red); color: white; }
/* Disabled state (aria-disabled="true"): visible but non-interactive — WCAG 2.2 */
.filter-btn[aria-disabled="true"] { opacity: 0.35; cursor: not-allowed; color: var(--muted); }
.filter-btn[aria-disabled="true"]:hover { border-color: var(--border); color: var(--muted); }
.filter-btn[aria-disabled="true"]:focus-visible { outline: 2px solid var(--muted); outline-offset: 2px; }
/* ── SECTION HEADER ── */
.section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; padding-top: 0; }
.section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(1.625rem,5vw,2.625rem); letter-spacing: 3px; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.section-title::after { content: ''; height: 3px; width: 36px; background: var(--red); display: inline-block; vertical-align: middle; margin-bottom: 3px; }
/* ── CAROUSEL ── */
.carousel { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
/* ── CARD ── */
.card { cursor: pointer; position: relative; border-radius: var(--r-card); overflow: hidden; background: var(--surface); transition: transform 0.3s cubic-bezier(.34,1.56,.64,1); border: 1.5px solid transparent; display: block; text-decoration: none; color: inherit; }
.card:hover { transform: translateY(-8px) scale(1.02); }
.card:focus-visible { border-color: var(--red-focus); outline: none; transform: translateY(-4px); }
.card-img-wrap { width: 100%; aspect-ratio: 2/3; overflow: hidden; position: relative; background: var(--bg3); }
.card-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
.card:hover .card-img-wrap img { transform: scale(1.05); }
.poster-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; padding: 16px; position: absolute; inset: 0; }
.poster-placeholder .abbr { font-family: 'Bebas Neue', sans-serif; font-size: clamp(1.375rem,5vw,1.875rem); color: rgba(255,255,255,0.7); letter-spacing: 3px; text-align: center; }
.poster-placeholder .pp-title { font-size: 0.65rem; color: rgba(255,255,255,0.35); letter-spacing: 1px; text-align: center; line-height: 1.3; }
.card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.3) 50%, transparent 100%); opacity: 0; transition: opacity 0.25s; display: flex; flex-direction: column; justify-content: flex-end; padding: 14px 12px; pointer-events: none; }
.card:hover .card-overlay, .card:focus-visible .card-overlay { opacity: 1; }
.card-overlay-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.05rem; letter-spacing: 1px; margin-bottom: 3px; }
.card-overlay-sessions { font-size: 0.7rem; color: var(--red-light); }
.card-info { padding: 11px 11px 13px; }
.card-title { font-size: 0.8rem; font-weight: 600; margin-bottom: 5px; overflow-wrap: break-word; }
.card-meta { display: flex; align-items: center; gap: 6px; font-size: 0.7rem; color: var(--muted); flex-wrap: wrap; }
.badge { background: rgba(192,57,43,.18); border: 1px solid rgba(192,57,43,.3); color: var(--red-light); padding: 0.15rem 0.45rem; border-radius: 4px; font-size: 0.65rem; font-weight: 700; letter-spacing: .5px; flex-shrink: 0; }
.badge.vo { background: rgba(232,201,122,.1); border-color: rgba(232,201,122,.2); color: var(--gold); }
/* ── SKELETON ── */
.skeleton { background: linear-gradient(90deg, var(--surface) 25%, var(--surface2) 50%, var(--surface) 75%); background-size: 200% 100%; animation: shimmer 1.6s infinite; border-radius: var(--r-card); }
@keyframes shimmer { to { background-position: -200% 0; } }
/* ── CINEMA LIST ── */
.cinema-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr)); gap: 12px; }
.cinema-card { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--r-card); padding: 1rem 1.125rem; cursor: pointer; transition: border-color .2s, transform .2s; position: relative; overflow: hidden; }
.cinema-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--red); transform: scaleY(0); transition: transform .2s; }
.cinema-card:hover { border-color: rgba(192,57,43,.4); transform: translateX(4px); }
.cinema-card:hover::before { transform: scaleY(1); }
.cinema-card:focus-visible { outline: none; border-color: var(--red-focus); box-shadow: 0 0 0 3px var(--red-focus); }
.cinema-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
.cinema-name { font-size: 0.95rem; font-weight: 600; margin-bottom: 4px; }
.maps-btn { display: inline-flex; align-items: center; gap: 5px; flex-shrink: 0; background: rgba(192,57,43,.12); border: 1.5px solid rgba(192,57,43,.25); color: var(--red-light); padding: 0.45rem 0.75rem; border-radius: 8px; font-size: 0.75rem; font-weight: 600; letter-spacing: .5px; text-decoration: none; transition: background .18s, border-color .18s, transform .15s; min-height: 44px; }
.maps-btn:hover { background: rgba(192,57,43,.28); border-color: var(--red); color: var(--text); transform: translateY(-1px); }
.cinema-location { font-size: 0.75rem; color: var(--muted); display: flex; align-items: flex-start; gap: 5px; margin-bottom: 10px; flex-wrap: wrap; }
.cinema-films-count { font-size: 0.75rem; color: var(--red-light); font-weight: 500; }
/* ── MODAL ── */
.modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.88); z-index: 500; display: flex; align-items: center; justify-content: center; padding: 16px; opacity: 0; pointer-events: none; transition: opacity .25s; backdrop-filter: blur(14px); }
.modal-backdrop.open { opacity: 1; pointer-events: all; }
.modal-backdrop.open .modal { transform: translateY(0) scale(1); }
.modal { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r-modal); max-width: 820px; width: 100%; max-height: 92dvh; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--red) transparent; transform: translateY(28px) scale(.97); transition: transform .3s cubic-bezier(.34,1.56,.64,1); position: relative; outline: none; }
.modal::-webkit-scrollbar { width: 4px; }
.modal::-webkit-scrollbar-thumb { background: var(--red); border-radius: 4px; }
.modal-hero { position: relative; min-height: clamp(8.75rem,25vw,15rem); overflow: hidden; border-radius: var(--r-modal) var(--r-modal) 0 0; }
.modal-bg { width: 100%; height: 100%; object-fit: cover; filter: blur(3px) brightness(.35); display: block; }
.modal-hero-content { position: absolute; inset: 0; display: flex; align-items: flex-end; padding: clamp(0.875rem,4vw,1.75rem); background: linear-gradient(to top, rgba(10,10,12,.98) 0%, transparent 65%); gap: 18px; }
.modal-poster { width: clamp(4.7rem,12vw,6.875rem); aspect-ratio: 2/3; border-radius: 8px; overflow: hidden; flex-shrink: 0; box-shadow: 0 20px 40px rgba(0,0,0,.55); background: var(--surface); }
.modal-poster img { width: 100%; height: 100%; object-fit: cover; display: block; }
.modal-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(1.5rem,5vw,2.625rem); letter-spacing: 2px; line-height: 1; margin-bottom: 0.5rem; }
.modal-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.tag { background: rgba(255,255,255,.08); padding: 0.2rem 0.65rem; border-radius: 5px; font-size: 0.7rem; color: var(--muted); letter-spacing: .8px; }
.modal-body { padding: clamp(1rem,4vw,1.75rem); }
.modal-synopsis { font-size: 0.875rem; color: var(--text-mid); line-height: 1.75; margin-bottom: 1.75rem; font-weight: 300; }
.modal-section-title { font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; color: var(--red-light); margin-bottom: 0.875rem; display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap; }
.modal-section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.sessions-grid { display: flex; flex-direction: column; gap: 14px; }
.session-cinema { background: var(--surface); border-radius: 10px; padding: 0.9rem 1.05rem; border: 1px solid var(--border); }
.session-cinema-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; gap: 8px; }
.session-cinema-name-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.session-cinema-name { font-size: 0.875rem; font-weight: 600; overflow-wrap: break-word; }
.session-maps-link { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.5px; color: var(--red-light); text-decoration: none; border-bottom: 1px solid rgba(231,76,60,.35); transition: color .15s, border-color .15s; white-space: nowrap; padding-bottom: 1px; }
.session-maps-link:hover { color: var(--text); border-color: var(--text); }
.session-cinema-name-link { text-decoration: none; color: inherit; border-bottom: 1px solid rgba(240,240,240,.2); transition: color .15s, border-color .15s; padding-bottom: 1px; }
.session-cinema-name-link:hover { color: var(--red-light); border-color: var(--red-light); }
.trailer-btn { display: inline-flex; align-items: center; gap: 7px; background: rgba(255,255,255,.06); border: 1.5px solid rgba(255,255,255,.12); color: var(--text); padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.5px; text-decoration: none; transition: background .18s, border-color .18s; min-height: 44px; margin-bottom: 1.5rem; }
.trailer-btn:hover { background: rgba(255,0,0,.15); border-color: rgba(255,60,60,.4); color: white; }
.trailer-btn svg { flex-shrink: 0; }
.session-cinema-city { font-size: 0.75rem; color: var(--muted); margin-top: 2px; display: inline-flex; align-items: center; gap: 6px; }
.session-city-sep { color: var(--border); line-height: 1; }
.session-times { display: flex; flex-wrap: wrap; gap: 8px; }
.session-time { background: rgba(192,57,43,.13); border: 1.5px solid rgba(192,57,43,.22); color: var(--text); padding: 0.5rem 0.8rem; border-radius: 8px; font-family: 'Space Mono', monospace; font-size: 0.8rem; cursor: pointer; transition: background .15s, border-color .15s; display: flex; align-items: center; gap: 6px; min-height: 44px; }
.session-time:hover { background: rgba(192,57,43,.28); border-color: var(--red); }
/* On the film detail page sessions are purely informational — remove interactive styling */
.film-body .session-time { cursor: default; }
.film-body .session-time:hover { background: rgba(192,57,43,.13); border-color: rgba(192,57,43,.22); }
.session-time-lang { font-size: 0.6rem; color: var(--red-light); letter-spacing: .8px; }
.close-btn { position: absolute; top: 0.875rem; right: 0.875rem; width: 2.75rem; height: 2.75rem; border-radius: 50%; background: rgba(0,0,0,.55); border: 1.5px solid var(--border); color: var(--text); font-size: 1.125rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .2s; z-index: 10; line-height: 1; }
.close-btn:hover { background: rgba(192,57,43,.45); }
.status-msg { color: var(--muted); font-size: 0.875rem; padding: 20px 0; }
/* ── ANIMATIONS ── */
.fade-up { opacity: 0; transform: translateY(22px); animation: fadeUp .55s ease forwards; }
@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
.card { animation: fadeUp .45s ease forwards; opacity: 0; }
.card:nth-child(1){animation-delay:.04s}.card:nth-child(2){animation-delay:.09s}.card:nth-child(3){animation-delay:.14s}.card:nth-child(4){animation-delay:.19s}.card:nth-child(5){animation-delay:.24s}.card:nth-child(6){animation-delay:.29s}.card:nth-child(7){animation-delay:.34s}.card:nth-child(8){animation-delay:.39s}
/* ── FOOTER ── */
footer { position: relative; overflow: hidden; padding: clamp(3rem,8vw,5rem) var(--px) clamp(2.25rem,5vw,3.5rem); margin-top: 3.75rem; }
.footer-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 60%, rgba(192,57,43,.15) 0%, transparent 55%), radial-gradient(ellipse at 80% 20%, rgba(146,43,33,.1) 0%, transparent 50%); }
.footer-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse at 30% 60%, black 10%, transparent 75%); }
.footer-inner { position: relative; z-index: 2; display: flex; flex-direction: column; gap: 2.5rem; }
.footer-top { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 32px; }
.footer-headline { display: flex; flex-direction: column; gap: 10px; }
.footer-eyebrow { font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 4px; color: var(--red-light); text-transform: uppercase; display: flex; align-items: center; gap: 10px; }
.footer-eyebrow::before { content: ''; width: 24px; height: 1px; background: var(--red); flex-shrink: 0; }
.footer-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.625rem, 7vw, 5.5rem); line-height: 0.92; letter-spacing: 2px; }
