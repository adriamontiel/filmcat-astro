---
// index.astro — SSR home page: fetch all data, render HTML with structured data
import Base       from '../layouts/Base.astro';
import Header     from '../components/Header.astro';
import Hero       from '../components/Hero.astro';
import FilmCard   from '../components/FilmCard.astro';
import CinemaCard from '../components/CinemaCard.astro';
import Footer     from '../components/Footer.astro';

import { fetchFilms, fetchCinemas } from '../lib/filmcat';
import { fetchTMDBPoster }          from '../lib/tmdb';
import { slugify }                  from '../lib/slug';
import { cityToProvince, PROVINCE_ORDER } from '../lib/provinces';

// ── Fetch all data in parallel ──
const [{ films, comingSoon }, cinemasFromApi] = await Promise.all([
  fetchFilms(),
  fetchCinemas(),
]);

// ── TMDB posters (server-side, API key stays private) ──
await Promise.allSettled(
  [...films, ...comingSoon].map(async film => {
    const result = await fetchTMDBPoster(film.searchTitle, film.year);
    if (result) {
      film.posterPath   = result.posterPath;
      film.backdropPath = result.backdropPath;
      film._tmdbId      = result.tmdbId;
    }
  })
);

// ── Count films per cinema ──
const cinemaFilmCount: Record<string, number> = {};
const cinemaCityMap:   Record<string, string> = {};
for (const film of films) {
  for (const session of film.sessions) {
    cinemaFilmCount[session.cinema] = (cinemaFilmCount[session.cinema] ?? 0) + 1;
    cinemaCityMap[session.cinema]   = session.city;
  }
}

// ── Cinemas: use API data if available, else derive from sessions ──
import type { Cinema } from '../lib/types';
let cinemas: Cinema[];

if (cinemasFromApi.length > 0) {
  cinemas = cinemasFromApi;
  for (const cinema of cinemas) {
    cinema.films = cinemaFilmCount[cinema.name] ?? 0;
  }
} else {
  // Derive cinemas from session data (Gencat cinema XML is often empty)
  const seen = new Set<string>();
  cinemas = [];
  for (const film of films) {
    for (const session of film.sessions) {
      if (!seen.has(session.cinema)) {
        seen.add(session.cinema);
        cinemas.push({
          id:       session.cinema,
          name:     session.cinema,
          address:  '',
          city:     session.city,
          province: '',
          lat:      null,
          lng:      null,
          films:    cinemaFilmCount[session.cinema] ?? 1,
        });
      }
    }
  }
  cinemas.sort((a, b) => (b.films ?? 0) - (a.films ?? 0));
}

// ── Available provinces this week (only show filter if >1 province) ──
const allProvinces = new Set<string>();
for (const film of films) {
  for (const session of film.sessions) allProvinces.add(cityToProvince(session.city));
}
const availableProvinces = PROVINCE_ORDER.filter(p => allProvinces.has(p));

// ── Stats ──
const sessionCount = films.reduce((a, f) => a + f.sessions.reduce((b, s) => b + s.times.length, 0), 0);

// ── Cache header: 7 days, revalidate in background ──
Astro.response.headers.set('Cache-Control', 's-maxage=604800, stale-while-revalidate=86400');

// ── JSON-LD ItemList ──
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://filmcat.cat';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cartellera de Cinema en Català',
  description: 'Totes les pel·lícules en català als cinemes de Catalunya',
  numberOfItems: films.length,
  itemListElement: films.map((film, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Movie',
      name: film.title,
      url:  `${siteUrl}/films/${slugify(film.title)}`,
      ...(film.posterPath ? { image: `https://image.tmdb.org/t/p/w500${film.posterPath}` } : {}),
      datePublished: String(film.year),
    },
  })),
};
const jsonLdStr = JSON.stringify(jsonLd).replace(/<\/script>/gi, '<\\/script>');
---

<Base
  title="FILMCAT — Cinema en Català"
  description="Totes les pel·lícules en català als cinemes de Catalunya. Horaris, sessions i cinemes actualitzats cada dijous."
  canonical={`${siteUrl}/`}
>
  <Header />

  <Hero
    filmCount={films.length}
    cinemaCount={cinemas.length}
    sessionCount={sessionCount}
  />

  <main id="main-content">

    <!-- ── CARTELLERA ── -->
    <section aria-labelledby="cartellera-h" id="avui" style="padding-top: 32px">
      {availableProvinces.length > 1 && (
        <div class="filter-bar" role="group" aria-label="Filtrar pel·lícules per província" data-filter-type="province">
          <button class="filter-btn active" data-province-filter="all" aria-pressed="true">Totes</button>
          {availableProvinces.map(province => (
            <button class="filter-btn" data-province-filter={province} aria-pressed="false">{province}</button>
          ))}
        </div>
      )}

      <div class="filter-bar" role="group" aria-label="Filtrar pel·lícules per versió" data-filter-type="version">
        <button class="filter-btn active" data-filter="all"  aria-pressed="true">Totes</button>
        <button class="filter-btn"        data-filter="VD"   aria-pressed="false">Doblada (VD)</button>
        <button class="filter-btn"        data-filter="VO"   aria-pressed="false">Versió Original</button>
        <button class="filter-btn"        data-filter="VOSC" aria-pressed="false">Sub. Català</button>
      </div>

      <div class="section-header">
        <h2 class="section-title" id="cartellera-h" style="scroll-margin-top: 80px">En Cartellera</h2>
      </div>

      <div class="carousel-wrap">
        <div class="carousel" id="mainCarousel" role="list" aria-label="Pel·lícules en cartellera">
          {films.map(film => <FilmCard film={film} />)}
        </div>
      </div>
    </section>

    <!-- ── PRÒXIMES ESTRENES ── -->
    {comingSoon.length > 0 && (
      <section aria-labelledby="upcoming-h" style="margin-top: clamp(3rem, 8vw, 5rem)">
        <div class="section-header">
          <h2 class="section-title" id="upcoming-h">Pròximes Estrenes</h2>
        </div>
        <div class="carousel-wrap">
          <div class="carousel" id="upcomingCarousel" role="list" aria-label="Pròximes estrenes en català">
            {comingSoon.map(film => <FilmCard film={film} />)}
          </div>
        </div>
      </section>
    )}

    <!-- ── CINEMES ── -->
    <section aria-labelledby="cinemes-h" id="cinemes" style="margin-top: clamp(3rem, 8vw, 5rem)">
      <div class="section-header">
        <h2 class="section-title" id="cinemes-h">Cinemes</h2>
      </div>
      <div class="cinema-list" id="cinemaList" role="list">
        {cinemas.map(cinema => <CinemaCard cinema={cinema} />)}
      </div>
    </section>

  </main>

  <!-- ── MODAL (quick-view, not used when cards are links) ── -->
  <div class="modal-backdrop" id="modalBackdrop" role="dialog" aria-modal="true"
       aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal" id="modal" tabindex="-1">
      <button class="close-btn" id="modalCloseBtn" aria-label="Tancar">✕</button>
      <div class="modal-hero" aria-hidden="true">
        <img class="modal-bg" id="modalBgImg" src="" alt="" role="presentation">
        <div class="modal-hero-content">
          <div class="modal-poster"><img id="modalPosterImg" src="" alt=""></div>
          <div>
            <h2 class="modal-title" id="modalTitle"></h2>
            <div class="modal-tags" id="modalTags"></div>
          </div>
        </div>
      </div>
      <div class="modal-body">
        <p class="modal-synopsis" id="modalSynopsis"></p>
        <div id="modalTrailer"></div>
        <h3 class="modal-section-title">Sessions disponibles</h3>
        <div class="sessions-grid" id="modalSessions" role="list" aria-label="Sessions disponibles"></div>
      </div>
    </div>
  </div>

  <Footer
    filmCount={films.length}
    cinemaCount={cinemas.length}
    sessionCount={sessionCount}
  />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={jsonLdStr}></script>
</Base>
