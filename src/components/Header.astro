---
// Header.astro — fixed top bar with logo + desktop nav + hamburger button
---
<header role="banner">
  <a class="logo-wrap" href="/" aria-label="FILMCAT - Inici">
    <svg class="logo-svg" viewBox="0 0 100 88" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="lg1" x1="0" y1="88" x2="100" y2="0" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#922B21"/>
          <stop offset="100%" stop-color="#E74C3C"/>
        </linearGradient>
        <linearGradient id="lg2" x1="50" y1="0" x2="0" y2="88" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#C0392B" stop-opacity=".85"/>
          <stop offset="100%" stop-color="#7B241C"/>
        </linearGradient>
      </defs>
      <polygon points="50,0 100,88 0,88" fill="url(#lg1)"/>
      <polygon points="50,0 50,60 0,88" fill="url(#lg2)"/>
    </svg>
    <span class="logo-text">FILMCAT</span>
  </a>

  <nav aria-label="Navegació principal">
    <a href="#cartellera-h">Cartellera</a>
    <a href="#cinemes">Cinemes</a>
  </nav>

  <button
    class="hamburger"
    aria-label="Obrir menú de navegació"
    aria-expanded="false"
    aria-controls="mobile-nav"
    id="hamburgerBtn"
  >
    <span class="menu-label">MENU</span>
  </button>
</header>

<nav id="mobile-nav" class="mobile-nav" aria-label="Menú mòbil" aria-hidden="true">
  <a href="#cartellera-h">Cartellera</a>
  <a href="#cinemes">Cinemes</a>
</nav>
